# Copy to .env and fill in values. Never commit .env.

# Database (e.g. postgresql://user:password@localhost:5432/dbname)
DATABASE_URL=

# Redis (e.g. redis://localhost:6379)
REDIS_URL=

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auth (use a long random string in production)
JWT_SECRET=

# AWS — S3 object storage
S3_BUCKET=
AWS_REGION=

# AWS SES — verified sender address
SES_FROM_EMAIL=

# Error monitoring (optional in dev)
SENTRY_DSN=

# development | production | test
NODE_ENV=development

# Public app URL (browser)
CLIENT_URL=http://localhost:5173

# API / server base URL
SERVER_URL=http://localhost:3000
