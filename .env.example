# Copy to .env and fill in values. Never commit .env.

DATABASE_URL=

REDIS_URL=

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auth (use a long random string in production)
JWT_SECRET=

# AWS — S3 object storage
S3_BUCKET=
AWS_REGION=

# AWS SES — verified sender address
SES_FROM_EMAIL=

# Error monitoring (optional in dev)
SENTRY_DSN=

# development | production | test
NODE_ENV=development

# Public app URL (browser)
CLIENT_URL=http://localhost:5173

# API / server base URL
SERVER_URL=http://localhost:3001

# Browser → API (Vite). Use the same hostname as the tab (localhost vs 127.0.0.1) or cookies will not attach.
VITE_API_URL=http://localhost:3001
