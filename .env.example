# Copy to .env and fill in values. Never commit .env.

DATABASE_URL=

# Local Docker Compose (redis service on 6379)
REDIS_URL=redis://127.0.0.1:6379

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auth (use a long random string in production)
JWT_SECRET=

# AWS — S3 object storage (presigned uploads; IAM user or env keys locally, instance role on EC2)
S3_BUCKET=
AWS_REGION=
# Optional: public URL origin if using CloudFront or a custom endpoint (default: https://{bucket}.s3.{region}.amazonaws.com)
# S3_PUBLIC_BASE_URL=
# Local dev: create an IAM user with s3:PutObject on arn:aws:s3:::YOUR_BUCKET/tmp/*
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Bucket CORS: allow PUT from CLIENT_URL; expose ETag if needed. See docs/The-Long-And-Winding-Road.md Step 10.

# Resend — transactional email (resend.com)
RESEND_API_KEY=
# Verified sender address (must match a domain verified in your Resend account)
FROM_EMAIL=noreply@yourdomain.com

# Error monitoring (optional in dev). When set, unhandled errors are reported to Sentry.
SENTRY_DSN=

# Server logs: JSON in production. In development, pino-pretty is used unless LOG_PRETTY=0.
# LOG_PRETTY=1
# LOG_PRETTY=0
LOG_LEVEL=info

# AI Insight Engine (Phase 5) — get a free key at aistudio.google.com
GEMINI_API_KEY=
# Optional fallback: OpenRouter (openrouter.ai) — used only when GEMINI_API_KEY is absent
# OPENROUTER_API_KEY=

# Onboarding — auto-follow on first signup
# Slug of the workspace every new user auto-follows on first signup (e.g. the LoopIn showcase board).
# Leave empty to disable auto-follow. Must be a public workspace that exists.
ONBOARDING_FEATURED_SLUG=

# development | production | test
NODE_ENV=development

# Public app URL (browser)
CLIENT_URL=http://localhost:5173

# API / server base URL
SERVER_URL=http://localhost:3001

# Browser → API (Vite). Use the same hostname as the tab (localhost vs 127.0.0.1) or cookies will not attach.
VITE_API_URL=http://localhost:3001

# Rate limits (optional overrides) — RL_<BUCKET>_LIMIT / RL_<BUCKET>_WINDOW_MS.
# Buckets: AUTH, CREATEPOST, UPVOTE, COMMENT, UPLOAD, DEFAULT. Defaults live in middleware/rateLimit.ts.
# DEFAULT covers cheap public reads (explore + workspace/notification GETs); raise it for heavy local
# testing so the read-heavy SPA (×2 under React StrictMode) doesn't 429. Example: crank reads for dev:
# RL_DEFAULT_LIMIT=2000
# RL_CREATEPOST_LIMIT=100
# RL_CREATEPOST_WINDOW_MS=3600000
